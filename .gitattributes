# Normalize all text files to LF in the repo; checkout uses platform default.
* text=auto eol=lf

# Binary carve-outs — never touch line endings on these.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.docx  binary
*.xlsx  binary
*.pptx  binary
*.grib  binary
*.grib2 binary
*.bin   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
