# SailLine Backend — Environment Variables
# Copy this file to .env (or .env.local) and fill in values for local dev.
# In production, these are injected by Cloud Run from Secret Manager.

# Cloud Run injects this automatically; default for local docker run.
PORT=8080

# === GCP project ===
GCP_PROJECT_ID=sailline

# === Cloud SQL (set after 03-vpc-and-cloud-sql.md) ===
CLOUD_SQL_INSTANCE=sailline:us-central1:sailline-db
DB_HOST=10.69.0.3
DB_NAME=sailline_app
DB_USER=sailline
# DB_PASSWORD pulled from Secret Manager at runtime — never store in .env

# === Memorystore Redis (set after 04-memorystore-and-storage.md) ===
REDIS_HOST=10.69.0.4
REDIS_PORT=6379

# === Cloud Storage ===
GCS_WEATHER_BUCKET=sailline-weather

# === External APIs (added later) ===
# DATALASTIC_API_KEY=
# ANTHROPIC_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
