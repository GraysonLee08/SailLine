# === Python (backend) ===
__pycache__/
*.py[cod]
*.so
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# === Node (frontend) ===
node_modules/
*.log
npm-debug.log*
.npm
.eslintcache
*.tgz

# === Build output ===
dist/
build/
coverage/
.nyc_output/

# === Firebase ===
.firebase/
firebase-debug.log*
.dataconnect

# === Env files ===
.env
.env.local
.env.*.local

# === Backend data artifacts ===
backend/tests/fixtures/*.grib2
backend/ingest_output/

# === Editors ===
.vscode/
.idea/

# === OS ===
.DS_Store
Thumbs.db

# === Capacitor (Android native shell) ===
# The android/ directory itself is intentionally committed (it is the
# native project). Below are per-machine and build artefacts that must
# not be checked in.
frontend/android/.gradle/
frontend/android/.idea/
frontend/android/local.properties
frontend/android/build/
frontend/android/app/build/
frontend/android/captures/
frontend/android/app/release/
# Release keystores must never be committed. Debug keystore is auto-
# generated locally; ignore both to be safe.
frontend/android/**/*.keystore
frontend/android/**/*.jks
# Capacitor sync artefacts copied from frontend/dist/ — regenerated on
# every `npx cap sync`, no need to track.
frontend/android/app/src/main/assets/public/
frontend/android/app/src/main/assets/capacitor.config.json
frontend/android/app/src/main/assets/capacitor.plugins.json
